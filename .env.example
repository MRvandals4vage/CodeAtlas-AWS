# ===================================================================
# CodeAtlas Environment Variables
# Copy this file to .env and adjust values as needed.
# ===================================================================

# ------ General ------
NODE_ENV=development

# ------ AI Configuration ------
# Add your Groq API key here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ------ Backend ------
BACKEND_PORT=5001
FRONTEND_PORT=3000

# ------ Frontend ------
# The URL where the backend API is reachable from the browser.
# For local dev this is http://localhost:5001.
# In Docker / production, set to the appropriate host.
NEXT_PUBLIC_API_URL=http://localhost:5001

# ------ Repo Cache & Cleanup ------
# How long cached analysis results stay valid (ms). Default: 1 hour.
# CACHE_TTL_MS=3600000

# Maximum number of cached analysis results. Default: 100.
# CACHE_MAX_ENTRIES=100

# Repos older than this are considered stale and swept (ms). Default: 10 min.
# STALE_REPO_AGE_MS=600000

# How often the background sweep runs (ms). Default: 5 min.
# CLEANUP_INTERVAL_MS=300000
